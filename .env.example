# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/fa_insight

# VLM Server (OpenAI-compatible API)
VLM_BASE_URL=http://vlm-server:8000/v1
VLM_API_KEY=dummy
VLM_MODEL=your-vlm-model-name

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# Processing
VLM_MAX_CONCURRENCY=5
VLM_RETRY_COUNT=2

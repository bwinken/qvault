# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fa_insight

# VLM Server (OpenAI-compatible API)
VLM_BASE_URL=http://vlm-server:8000/v1
VLM_API_KEY=dummy
VLM_MODEL=your-vlm-model-name
VLM_EMBEDDING_MODEL=your-embedding-model-name

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# Processing
VLM_MAX_CONCURRENCY=5
VLM_RETRY_COUNT=2

# OAuth 2.0 (Auth Center)
OAUTH_CLIENT_ID=fa-insight-harvester
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_AUTH_URL=http://authcenter.internal/auth/login
OAUTH_TOKEN_URL=http://authcenter.internal/auth/token
OAUTH_PUBLIC_KEY_PATH=./auth_public_key.pem
OAUTH_REDIRECT_URI=http://your-server:8000/auth/callback

# App
APP_BASE_URL=http://your-server:8000

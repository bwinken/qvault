# ══════════════════════════════════════════════
# QVault — Single Configuration File
# ══════════════════════════════════════════════
# This file is used by BOTH the app AND docker-compose.
# Copy to .env and fill in the values.

# ── Data root (all runtime paths derived from this) ──
# Set this once; UPLOAD_DIR, LOG_DIR, AUTH_PUBLIC_KEY_PATH, PGDATA_DIR
# are automatically derived as DATA_DIR/uploads, DATA_DIR/logs, etc.
# You can still override any individual path below if needed.
DATA_DIR=/mnt/db/qvault

# ── PostgreSQL ──
# DATABASE_URL is auto-derived from these PG_* vars.
# Only set DATABASE_URL explicitly if you need a non-standard connection string.
PG_USER=qvault
PG_PASSWORD=change-me
PG_DB=qvault
PG_PORT=5432

# Connection pool — 10-20 人使用建議值如下
# pool_size = 常駐連線數，max_overflow = 尖峰時額外允許的連線數
# 總最大連線 = pool_size + max_overflow = 10 + 10 = 20
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300

# ── VLM Server (OpenAI-compatible API) ──
VLM_BASE_URL=http://vlm-server:8000/v1
VLM_API_KEY=dummy
VLM_MODEL=your-vlm-model-name
VLM_EMBEDDING_MODEL=your-embedding-model-name

# Processing
# 注意：VLM_MAX_CONCURRENCY 是 per-worker 的限制。
VLM_MAX_CONCURRENCY=5
VLM_RETRY_COUNT=2
VLM_TIMEOUT=120.0
SUBPROCESS_TIMEOUT=300.0

# VLM Sampling (Qwen3.5 Instruct defaults)
VLM_TEMPERATURE=0.7
VLM_TOP_P=0.8
VLM_TOP_K=20
VLM_MIN_P=0.0
VLM_PRESENCE_PENALTY=1.5
VLM_REPETITION_PENALTY=1.0

# Upload
MAX_UPLOAD_SIZE_MB=100

# ── OIDC Provider (Auth Center) — used by oauth2-proxy container ──
OIDC_ISSUER_URL=http://auth.company.com
OAUTH2_CLIENT_ID=qvault
OAUTH2_CLIENT_SECRET=change-me
OAUTH2_REDIRECT_URL=http://qvault.your-domain.com/oauth2/callback
OAUTH2_COOKIE_NAME=_qvault_oauth2
OAUTH2_COOKIE_SECRET=<run: openssl rand -base64 32>
OAUTH2_COOKIE_SECURE=false

# ── Auth (JWT verification) ──
DEV_SKIP_AUTH=false
# Set ENVIRONMENT=production on prod servers (blocks DEV_SKIP_AUTH)
# ENVIRONMENT=production

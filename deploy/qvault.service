[Unit]
Description=QVault — FA Case Management
After=network.target

[Service]
Type=exec
WorkingDirectory=%h/opt/qvault
EnvironmentFile=%h/opt/qvault/.env
Environment=PYTHONUTF8=1
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/uv run fastapi run app/main.py --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target

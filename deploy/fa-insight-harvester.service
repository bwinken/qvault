[Unit]
Description=FA Insight Harvester Web App
After=network.target postgresql.service

[Service]
Type=simple
WorkingDirectory=__APP_DIR__
EnvironmentFile=__APP_DIR__/.env
ExecStart=%h/.local/bin/uv run fastapi run app/main.py --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=default.target

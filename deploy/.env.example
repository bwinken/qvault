# ══════════════════════════════════════════════
# QVault — Docker Services Configuration
# ══════════════════════════════════════════════
# Used by docker-compose.yml (PostgreSQL only).
# App configuration is in the project root .env (see ../.env.example).
# Copy to deploy/.env and fill in the values.

# ── Data root ──
DATA_DIR=/mnt/db/qvault

# ── PostgreSQL ──
# Must match the PG_* values in the app's .env file.
PG_USER=qvault
PG_PASSWORD=change-me
PG_DB=qvault
PG_PORT=5432
